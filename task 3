#include <cstdio>
#include <cstdlib>
#include <iostream>
#include <stdio.h>
#include <ctime>
#include <chrono>
#include <thread>


class Sensor {

 protected:
 	 std::string name; 
 	 int sensor_ID;
 	 bool sensor_active = false;
 public: 
  void setName(std::string n) {
 	 name = n; 
	  }
  void displayName() { 
  	std::cout << "Sensor: " << name << std::endl; 
	  } 
  void setID(int a){
  	sensor_ID=a;
  }
	int getID(){
		return sensor_ID;
	}
	void enable(){
		sensor_active = true;
	}
	void disable(){
		sensor_active = false;
	}
	  
	  }; 
	  
	  
class GeigerCounter : public Sensor {
	private:
		int detectionCount;
		int timeSinceLastMeasurement;
		int currentTime;
		double detectionRate;
		double alarmThreshold;
		bool alarm;
	public:
		void addDetection(){
			if(sensor_active=true){
			detectionCount++;
		}
		}
		void updateReading(int UnixTime){
			if(sensor_active=true){
			timeSinceLastMeasurement=UnixTime-currentTime;
			detectionRate = detectionCount/timeSinceLastMeasurement;
			std::cout << "detection rate:" << detectionRate << std::endl;
			currentTime = UnixTime;
			detectionCount = 0;
			}
		}
		void setAlarmThreshold(double threshold){
			alarmThreshold=threshold;
		}
		void checkAlert(){
			if(alarmThreshold < detectionRate){
				alarm = true;
			}
		
		}
		void clearAlarm(){
			alarm = false;
		}
	
	
	
};


class LIDAR : public Sensor {
		private:
		int angles[90];
		int maxRange;
		int minRange;
		int measurements[90];
		bool collisionWarning[90];
	public:
		LIDAR(){
			for(int i=0; i<90; i++){
				angles[i]=i;
				collisionWarning[i]=false;
			}

			maxRange=100;
			minRange=10;
			std::cout << "Initializing LIADR... \n" << std::endl;
		}
		void writeDistance(int distance, int angle){
			if(distance > maxRange){
				distance = maxRange;
			}
			measurements[angle]=distance;
			if(distance < minRange){
				collisionWarning[angle] = true;
			}
			else{
				collisionWarning[angle] = false;
			}
		}
		void warningSweep(){
			for(int i=0; i<90; i++){
				if(collisionWarning[i]==true){
						std::cout << "WARNING angle:"  << i << "  distance: "<< measurements[i] << "\n" << std::endl;
				}
				else{
						std::cout << " angle:"  << i << "  clear \n" << std::endl;
				}
				
			}
			
			
		}
		double getDistance(int angle){
			return measurements[angle];
		}		
		int getClosest(){
			double closest;
			int closestAngle;
			closest = maxRange;
			for(int i=0; i<90; i++){
				if(measurements[i]<closest){
					closest = measurements[i];
					closestAngle=i;
				}
				
				
			}
			return closestAngle;
		}
		void setMaxRange(int range){
			maxRange = range;
		}
		void setMinRange(int range){
			minRange = range;
		}
	
	
	
};

	
	
	
	
	


int main(){
	time_t now;
	LIDAR L1;
	L1.enable();
	GeigerCounter G1;
	G1.enable();
	int a;
	int unixtime;
	unixtime = time(&now);
	G1.updateReading(unixtime);
	
	
	for(int i=0; i<90; i++){
		a = rand()%1000;
		for(a; a>0; a--){
			G1.addDetection();
		}
		std::chrono::milliseconds timespan(1000);
		std::this_thread::sleep_for(timespan);
		unixtime = time(&now);
		G1.updateReading(unixtime);
		L1.writeDistance(a,i);
		
		
		
		
		
		
		
		
	}
	
	L1.warningSweep();
	
	
	return 0;
}
